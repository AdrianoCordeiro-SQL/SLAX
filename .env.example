DATABASE_URL=postgresql://user:password@db:5432/portfolio_db
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=portfolio_db
JWT_SECRET=slax-seu-segredo-super-secreto-indescobrivel
# Comma-separated browser origins (required for CORS with credentials in production).
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# Opcional: botão "Entrar como visitante" (POST /auth/demo). A conta tem de existir na BD (seed cria admin@slax.com).
DEMO_LOGIN_EMAIL=admin@slax.com
DEMO_LOGIN_PASSWORD=admin123

# Frontend: controla a visibilidade do botão "Entrar como visitante" na tela de login.
NEXT_PUBLIC_ENABLE_DEMO_LOGIN=true
